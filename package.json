{
  "name": "vitepress-plugin-color-preview",
  "version": "0.3.2",
  "description": "VitePress plugin that renders color swatches next to color codes in inline code blocks",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./client": {
      "import": "./dist/client.js",
      "types": "./dist/client.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.ts' '*.{json,md,css}'",
    "format:check": "prettier --check 'src/**/*.ts' '*.{json,md,css}'",
    "prepare": "husky"
  },
  "keywords": [
    "vitepress",
    "markdown-it",
    "color",
    "preview",
    "swatch",
    "plugin"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/KlangHaus/vitepress-plugin-color-preview.git"
  },
  "bugs": {
    "url": "https://github.com/KlangHaus/vitepress-plugin-color-preview/issues"
  },
  "homepage": "https://klanghaus.github.io/vitepress-plugin-color-preview/",
  "peerDependencies": {
    "markdown-it": ">=13.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@eslint/js": "^10.0.1",
    "@types/markdown-it": "^14.0.0",
    "eslint": "^10.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "markdown-it": "^14.0.0",
    "prettier": "^3.8.1",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.56.1"
  }
}
